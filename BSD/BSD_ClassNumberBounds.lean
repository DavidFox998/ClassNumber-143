-- ============================================================
-- §7. Conditional class number via BQF bridge (combinator)
-- ============================================================

/-- **COMBINATOR** (0 sorry, classical trio):
    Given `BSD_BQF_ClassNumber_bridge_OPEN` (the Gauss–Dirichlet bijection
    reduced-forms ↔ ClassGroup(𝓞 K)), combined with the proved BQF count
    `BSD_numReducedForms143` (length = 10), derive classNumber K = 10.

    Proof: bridge says classNumber K = reducedForms143.length,
    and BSD_numReducedForms143 says reducedForms143.length = 10. -/
theorem BSD_classNumber_via_bqf_bridge
    (h_bridge : BSD_BQF_ClassNumber_bridge_OPEN) :
    NumberField.classNumber K = 10 := by
  unfold BSD_BQF_ClassNumber_bridge_OPEN at h_bridge
  rw [h_bridge]
  exact BSD_numReducedForms143

/-- **COMBINATOR** (0 sorry, classical trio):
    Upper bound: given the BQF bridge, classNumber K ≤ 10. -/
theorem BSD_upper_via_bqf
    (h_bridge : BSD_BQF_ClassNumber_bridge_OPEN) :
    K1_ClassNumber_Upper_BSD :=
  Nat.le_of_eq (BSD_classNumber_via_bqf_bridge h_bridge)

/-- **COMBINATOR** (0 sorry, classical trio):
    Lower bound: given the BQF bridge, 10 ≤ classNumber K. -/
theorem BSD_lower_via_bqf
    (h_bridge : BSD_BQF_ClassNumber_bridge_OPEN) :
    K1_ClassNumber_Lower_BSD :=
  Nat.le_of_eq (BSD_classNumber_via_bqf_bridge h_bridge).symm

