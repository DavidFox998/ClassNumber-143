/-! ## §1. If classNumber K = 10, then [p₂] generates ClassGroup -/

/-- **BSD_classGroup_gen_by_p2_of_card_10** (0 sorry, classical trio):
    If classNumber K = 10 and p₂^10 is principal, then ClassGroup(𝓞 K) is
    generated by [p₂].

    Key steps:
    - orderOf([p₂]) = 10  (from BSD_orderOf_p2_eq_10 + hprinc).
    - Fintype.card(ClassGroup) = classNumber K = 10.
    - Fin 10 → ClassGroup, k ↦ [p₂]^k, is injective (since orderOf = 10,
      distinct powers on {0,...,9}).
    - Image has card 10 = card ClassGroup → image = Finset.univ.
    - Hence every x is a power of [p₂], i.e. x ∈ Subgroup.zpowers [p₂]. -/
theorem BSD_classGroup_gen_by_p2_of_card_10
    (hprinc : BSD_p2_pow_10_principal_hyp)
    (hcard10 : NumberField.classNumber K = 10) :
    BSD_classGroup_gen_by_p2_hyp := by
  have hp2ne : p2_OK ≠ 0 := by
    intro h; have := absNorm_p2_eq_2
    rw [h, Ideal.zero_eq_bot, Ideal.absNorm_bot] at this; norm_num at this
  let I₂ : (Ideal (𝓞 K))⁰ := ⟨p2_OK, mem_nonZeroDivisors_iff_ne_zero.mpr hp2ne⟩
  let g : ClassGroup (𝓞 K) := ClassGroup.mk0 I₂
  -- orderOf([p₂]) = 10
  have hord : orderOf g = 10 := BSD_orderOf_p2_eq_10 hprinc
  -- Fintype.card(ClassGroup) = 10  (since classNumber K = Fintype.card ClassGroup by def)
  have hcard_G : Fintype.card (ClassGroup (𝓞 K)) = 10 := hcard10
  -- The map Fin 10 → ClassGroup, k ↦ g^k, is injective
  -- (if g^a = g^b then orderOf g | a-b, so 10 | a-b; since |a-b| < 10, a = b)
  have hinj : Function.Injective (fun k : Fin 10 => g ^ (k : ℤ)) := by
    intro ⟨a, ha⟩ ⟨b, hb⟩ hab
    simp only [Fin.mk.injEq]
    have h1 : g ^ ((a : ℤ) - (b : ℤ)) = 1 := by
      rw [zpow_sub, show g ^ (a : ℤ) = g ^ (b : ℤ) from hab, mul_inv_cancel]
    have hdvd : (orderOf g : ℤ) ∣ (a : ℤ) - b :=
      orderOf_dvd_of_zpow_eq_one g _ h1
    rw [hord] at hdvd
    have ha' : (a : ℤ) < 10 := by exact_mod_cast ha
    have hb' : (b : ℤ) < 10 := by exact_mod_cast hb
    have ha0 : (0 : ℤ) ≤ a := Int.coe_nat_nonneg _
    have hb0 : (0 : ℤ) ≤ b := Int.coe_nat_nonneg _
    omega
  -- The image {g^0, g^1, ..., g^9} has card = 10 = card(ClassGroup)
  have hcard_img : (Finset.image (fun k : Fin 10 => g ^ (k : ℤ)) Finset.univ).card =
                   (Finset.univ : Finset (ClassGroup (𝓞 K))).card := by
    rw [Finset.card_image_of_injective _ hinj, Finset.card_univ, Fintype.card_fin,
        Finset.card_univ, hcard_G]
  -- Image = ClassGroup (by card equality: image ⊆ univ and same card)
  have himg : Finset.image (fun k : Fin 10 => g ^ (k : ℤ)) Finset.univ = Finset.univ :=
    Finset.eq_of_subset_of_card_le (Finset.subset_univ _) hcard_img.symm.le
  -- Prove BSD_classGroup_gen_by_p2_hyp: ∀ x, x ∈ Subgroup.zpowers g
  intro x
  obtain ⟨k, _, hk⟩ := Finset.mem_image.mp (himg ▸ Finset.mem_univ x)
  exact Subgroup.mem_zpowers_iff.mpr ⟨(k : ℤ), hk⟩

