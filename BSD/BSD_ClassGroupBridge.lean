theorem BSD_classGroup_gen_by_p2_of_bqf
    (h_bridge : BSD_BQF_ClassNumber_bridge) :
    BSD_classGroup_gen_by_p2_hyp :=
  BSD_classGroup_gen_by_p2_of_card_10
